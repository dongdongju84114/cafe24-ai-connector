PORT=4173
HOST=127.0.0.1

# Replace this with the real HTTPS hostname that reaches this connector.
# Examples:
# - https://cafe24-ai-dev.opengallery.co.kr
# - https://your-static-ngrok-domain.ngrok.app
PUBLIC_BASE_URL=https://cafe24-ai-dev.opengallery.co.kr

# Cafe24 Developer Admin credentials.
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
CAFE24_DEFAULT_MALL_ID=
CAFE24_API_VERSION=2026-03-01

# Keep the fixed application scopes if Cafe24 requires them for this app.
# Add/remove scopes here whenever the Developer Admin scope selection changes.
CAFE24_SCOPES=mall.read_application mall.write_application mall.read_order mall.read_product mall.read_category mall.read_store mall.read_salesreport mall.read_analytics

# Internal API protection. Use a long random value and keep it server-side.
INTERNAL_API_KEY=

# 32+ random bytes recommended. Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CAFE24_TOKEN_ENCRYPTION_KEY=
CAFE24_OAUTH_STATE_SECRET=

CAFE24_TOKEN_STORE_PATH=./data/tokens.enc.json
CAFE24_ALLOWED_ADMIN_PATH_PREFIXES=/api/v2/admin/orders,/api/v2/admin/products,/api/v2/admin/categories,/api/v2/admin/financials,/api/v2/admin/reports

# Optional: use docker-compose.cloudflare.yml after creating a Cloudflare Tunnel.
CLOUDFLARE_TUNNEL_TOKEN=
